{
  "name": "@routemarket/atlas-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "atlas": "./dist/apps/cli/src/index.js"
  },
  "scripts": {
    "atlas": "tsx --env-file=.env apps/cli/src/index.ts",
    "demo:golden-route": "tsx --env-file=.env scripts/demo-golden-route.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "api": "tsx --env-file=.env apps/api/src/index.ts",
    "mcp": "tsx --env-file=.env ../../packages/atlas-mcp/src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "@supabase/supabase-js": "^2.105.4",
    "@routemarket/atlas-core": "workspace:*",
    "@routemarket/atlas-client": "workspace:*",
    "@routemarket/atlas-gis": "workspace:*",
    "@routemarket/atlas-research": "workspace:*",
    "@routemarket/atlas-workflow": "workspace:*",
    "@routemarket/atlas-publisher": "workspace:*",
    "@routemarket/atlas-writer": "workspace:*",
    "commander": "^14.0.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
