{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@routemarket/atlas-core/*": ["../../packages/atlas-core/*"],
      "@routemarket/atlas-gis/*": ["../../packages/atlas-gis/*"],
      "@routemarket/atlas-research/*": ["../../packages/atlas-research/*"],
      "@routemarket/atlas-workflow/*": ["../../packages/atlas-workflow/*"],
      "@routemarket/atlas-publisher/*": ["../../packages/atlas-publisher/*"],
      "@routemarket/atlas-writer/*": ["../../packages/atlas-writer/*"]
    }
  },
  "include": [
    "apps/**/*.ts", 
    "../../packages/atlas-core/**/*.ts",
    "../../packages/atlas-gis/**/*.ts",
    "../../packages/atlas-research/**/*.ts",
    "../../packages/atlas-workflow/**/*.ts",
    "../../packages/atlas-publisher/**/*.ts",
    "../../packages/atlas-writer/**/*.ts",
    "../../packages/shared-workflow/**/*.ts"
  ]
}
